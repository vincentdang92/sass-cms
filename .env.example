# ==============================
# Environment Variables Template
# Copy sang .env và điền giá trị thực
# KHÔNG commit file .env lên git!
# ==============================

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=chatbot_db

# URL dùng cho SQLAlchemy (trong docker-compose dùng hostname "postgres")
DATABASE_URL=postgresql://chatbot:changeme123@postgres:5432/chatbot_db

# ── Qdrant ─────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── LLM API Keys ───────────────────────────────────────────────────────
# DeepSeek (mặc định — rẻ hơn OpenAI ~80%)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (tùy chọn — nếu customer chọn GPT-4o-mini)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin ──────────────────────────────────────────────────────────────
# Secret để gọi /admin/* endpoints
# Đặt chuỗi dài ngẫu nhiên: openssl rand -hex 32
ADMIN_SECRET=your-super-secret-admin-key-here

# ── MCP Tools ──────────────────────────────────────────────────────────
# WhoisFreaks API (miễn phí tier: 100 req/tháng)
# Đăng ký tại: https://whoisfreaks.com
WHOIS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Open WebUI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
